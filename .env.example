# NordVPN SOCKS5 Proxy Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values. Never commit .env.
#
# How to get credentials:
#   nordvpn.com → My Account → NordVPN Service → Manual Setup → Credentials tab
#   (These are SERVICE credentials, separate from your nordvpn.com login.)
#
# How to pick SOCKS5 server hostnames:
#   nordvpn.com/servers/tools/ → filter SOCKS5 → pick country codes
#   Port is always 1080.
#
# Example country-level hostnames (confirmed via NordVPN API March 2026):
#   socks-nl1.nordvpn.com  Netherlands
#   socks-nl2.nordvpn.com  Netherlands (alt)
#   socks-us28.nordvpn.com United States
#   socks-se8.nordvpn.com  Sweden
# Find more: curl -s "https://api.nordvpn.com/v1/servers?filters[servers_technologies][identifier]=socks&limit=50"
#            | python3 -c "import json,sys; [print(s['hostname']) for s in json.load(sys.stdin)]"
# ─────────────────────────────────────────────────────────────────────────────

NORDVPN_USER=your_service_username_here
NORDVPN_PASS=your_service_password_here

# Comma-separated list of SOCKS5 server hostnames to rotate through
NORDVPN_SERVERS=socks-nl1.nordvpn.com,socks-us28.nordvpn.com,socks-se8.nordvpn.com

# How many requests before proactively switching to the next proxy (default: 15)
PROXY_ROTATE_EVERY=15

# ─────────────────────────────────────────────────────────────────────────────
# LLM / Analysis
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-lite

# ─────────────────────────────────────────────────────────────────────────────
# Notion (required if auto_notion_push enabled)
# ─────────────────────────────────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_APARTMENTS_DB_ID=
NOTION_AREAS_DB_ID=
NOTION_AGENCIES_DB_ID=
