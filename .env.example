# ---- Proxy (IPRoyal residential) ----
IPROYAL_HOST=geo.iproyal.com
IPROYAL_PORT=12321
IPROYAL_USER=your_username
IPROYAL_PASS=your_password
IPROYAL_COUNTRY=it
IPROYAL_PROTOCOL=http
IPROYAL_STICKY_MINUTES=0

# ---- Browser ----
BROWSER_HEADLESS=true
BROWSER_MAX_REQUESTS=75
BROWSER_CONTEXT_RECYCLE=15
BROWSER_FETCH_TIMEOUT=90

# ---- LLM ----
OPENROUTER_API_KEY=sk-...
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
ANALYSIS_CONCURRENCY=5

# ---- Notion ----
NOTION_API_KEY=ntn_...
NOTION_APARTMENTS_DB_ID=...
NOTION_AREAS_DB_ID=...
NOTION_AGENCIES_DB_ID=...

# ---- Storage ----
DB_PATH=data/app.db
DATA_DIR=data
PREFERENCES_FILE=preferences.txt
